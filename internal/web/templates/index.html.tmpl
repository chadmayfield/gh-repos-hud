<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {{if .Watch}}<meta http-equiv="refresh" content="{{.Interval}}">{{end}}
  <title>gh-repos-hud</title>
  <link rel="stylesheet" href="/assets/app.css">
</head>
<body>
  <header>
    <h1>gh-repos-hud</h1>
    {{with .State}}
    <p class="meta">
      updated {{.FetchedAt.Format "15:04:05"}}
      · REST {{.RateLimit.RESTRemaining}}/{{.RateLimit.RESTLimit}}
      · GraphQL {{.RateLimit.GraphQLRemaining}}/{{.RateLimit.GraphQLLimit}}
      {{if .Warnings}}· <span class="warn">{{len .Warnings}} warning(s)</span>{{end}}
      · <a href="/?refresh=1">refresh</a>
      · auto-refresh {{if $.Watch}}on{{else}}<span class="muted">off (--watch to enable)</span>{{end}}
    </p>
    {{end}}
  </header>

  <main id="content">
  {{with .State}}
    <table>
      <colgroup>
        <col class="c-glyph"><col class="c-repo"><col class="c-ci"><col class="c-sha">
        <col class="c-tag"><col class="c-dep"><col class="c-num"><col class="c-num">
        <col class="c-undep"><col class="c-pr">
      </colgroup>
      <thead><tr>
        <th></th><th>repo</th><th>CI</th><th>SHA</th><th>tag</th>
        <th>dep C/H/M/L</th><th>code</th><th>secret</th><th>undep</th><th>PR b/h</th>
      </tr></thead>
      <tbody>
      {{range .Owners}}
        <tr class="org"><td colspan="10">
          {{.Name}}{{if .IsUser}} <span class="muted">(personal)</span>{{end}}
          {{if .Billing.Known}}{{if or .Billing.SecretProtectionCommitters .Billing.CodeSecurityCommitters}}
            <span class="ghas">GHAS secret={{.Billing.SecretProtectionCommitters}} code={{.Billing.CodeSecurityCommitters}}</span>
          {{end}}{{end}}
        </td></tr>
        {{range .Repos}}
        <tr class="h-{{.StatusName}}">
          <td class="glyph">{{.StatusGlyph}}</td>
          <td class="repo"><a href="{{.URL}}" target="_blank" rel="noopener">{{.Name}}</a>{{if not .Private}} <span class="pub">public</span>{{end}}</td>
          <td class="ci ci-{{.CI.String}}">{{.CI.Short}}</td>
          <td class="mono">{{.ShortSHA}}</td>
          <td class="mono">{{dash .LatestTag}}</td>
          <td class="mono">{{.Dependabot.Critical}}/{{.Dependabot.High}}/{{.Dependabot.Moderate}}/{{.Dependabot.Low}}</td>
          <td class="mono">{{scan .CodeScan .CodeScanning}}</td>
          <td class="mono">{{scan .SecretScan .SecretScanning}}</td>
          <td>{{.UndeployedLabel}}</td>
          <td class="mono">{{.PRs.Bot}}/{{.PRs.Human}}</td>
        </tr>
        {{end}}
      {{end}}
      </tbody>
    </table>
  {{else}}
    <p>loading repo health…</p>
  {{end}}
  </main>

  {{if .Watch}}<script src="/assets/poll.js" data-interval="{{.Interval}}"></script>{{end}}
</body>
</html>
